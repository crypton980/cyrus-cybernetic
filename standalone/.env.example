# ============================================================
# CYRUS v3.0 - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- REQUIRED ---

# PostgreSQL connection string
# For Docker Compose: leave as-is (auto-configured)
# For manual setup: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://cyrus:cyrus_secure_password@localhost:5432/cyrus

# OpenAI API Key (required for AI responses)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- OPTIONAL ---

# ElevenLabs API Key (for voice synthesis)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Google Maps API Key (for navigation features)
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=

# News API Key (for news features)
NEWS_API_KEY=

# --- SERVER ---

# Port to run on (default: 5000)
PORT=5000

# Set to "production" for production deployments
NODE_ENV=production

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=cyrus_secure_password

# --- SESSION ---

# Session secret for cookie signing (auto-generated if not set)
SESSION_SECRET=
