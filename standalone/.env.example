# ============================================================
# CYRUS v3.0 - Standalone Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED ----

# PostgreSQL connection string
# If using Docker Compose, leave this as-is (auto-configured internally)
# For manual setup: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://cyrus:cyrus_secure_password@localhost:5432/cyrus

# OpenAI API Key (powers all AI responses, image analysis, etc.)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- OPTIONAL SERVICES ----

# ElevenLabs API Key (for ultra-realistic voice synthesis)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Google Maps API Key (for navigation & location features)
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=

# News API Key (for news intelligence)
NEWS_API_KEY=

# ---- SERVER CONFIG ----

# Port CYRUS runs on (default: 5000)
PORT=5000

# ---- AUTHENTICATION ----

# Admin credentials (used for the admin login)
ADMIN_USERNAME=DELTA UNIFORM 00
ADMIN_ACCESS_CODE=71580019

# Standard user access code (any username + this code)
USER_ACCESS_CODE=170392

# Session secret for cookie signing (leave empty to auto-generate)
SESSION_SECRET=

# Encryption key material (required in production)
# Use long, random values and keep them secret.
ENCRYPTION_SECRET=
ENCRYPTION_SALT=

# ---- DOCKER COMPOSE ONLY ----

# PostgreSQL password (used by Docker Compose to create the database)
POSTGRES_PASSWORD=cyrus_secure_password

# Database port mapping on host (default: 5432)
DB_PORT=5432
