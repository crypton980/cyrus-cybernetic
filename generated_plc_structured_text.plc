// Generated_ST_Program
// Generated Structured Text Program
// Description: PID temperature control system

PROGRAM Generated_ST_Program
VAR
    Start_Button AT %IX0.0 : BOOL;
    Stop_Button AT %IX0.1 : BOOL;
    Motor_Run AT %QX0.0 : BOOL;
    Emergency_Stop AT %IX0.2 : BOOL;
    Timer_Run AT %QX0.1 : BOOL;
    Timer_Preset : TIME := T#5S;
    Timer_Current : TIME;
    Counter_Value : INT := 0;
END_VAR

// Main control logic
IF Emergency_Stop THEN
    Motor_Run := FALSE;
    Timer_Run := FALSE;
ELSIF Start_Button AND NOT Stop_Button THEN
    Motor_Run := TRUE;
    Timer_Run := TRUE;
ELSIF Stop_Button THEN
    Motor_Run := FALSE;
    Timer_Run := FALSE;
END_IF;

// Counter logic
IF Motor_Run AND Timer_Run THEN
    Counter_Value := Counter_Value + 1;
END_IF;

END_PROGRAM
