modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "pkg-config", "qhull", "tcl", "tk", "unzip", "xsimd", "zip", "zlib"]

[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_log_in_with_replit:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start CYRUS"

[[workflows.workflow]]
name = "Start CYRUS"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3001

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "python server/quantum_ai/quantum_bridge.py &>/dev/null & python server/comms/ml_service.py &>/dev/null & NODE_ENV=production node dist/server/index.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
ALPACA_ENVIRONMENT = "live"
