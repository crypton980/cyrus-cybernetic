{
  "name": "cyrus-ai-system",
  "version": "3.0.0",
  "description": "CYRUS AI System with Azure AI Integrations",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:original-ui": "CYRUS_UI_ROOT=original-cyrus-ui-extracted/client tsc && CYRUS_UI_ROOT=original-cyrus-ui-extracted/client vite build",
    "start": "node --experimental-specifier-resolution=node dist/server/index.js",
    "start:app": "TMPDIR=/tmp tsx server/index.ts",
    "start:app:original-ui": "NODE_ENV=development TMPDIR=/tmp tsx server/index.ts",
    "start:app:extracted-ui": "NODE_ENV=development CYRUS_UI_ROOT=original-cyrus-ui-extracted/client TMPDIR=/tmp tsx server/index.ts",
    "start:cluster": "TMPDIR=/tmp tsx server/cluster.ts",
    "start:clean": "bash scripts/start-clean.sh",
    "start:prod": "NODE_ENV=production TMPDIR=/tmp tsx server/index.ts",
    "start:prod:cluster": "NODE_ENV=production TMPDIR=/tmp tsx server/cluster.ts",
    "start:prod:dist": "NODE_ENV=production node --experimental-specifier-resolution=node dist/server/index.js",
    "start:all": "concurrently \"python3 cyrus-ai/api.py\" \"npm run start\"",
    "health:check": "bash scripts/health-check.sh",
    "dev": "tsx server/index.ts",
    "deploy": "npm run build"
  },
  "keywords": [
    "ai",
    "super-intelligence",
    "azure-openai",
    "document-intelligence",
    "express",
    "typescript"
  ],
  "author": "CYRUS Development Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.1.0",
    "@azure/identity": "^4.13.1",
    "@azure/openai": "^2.0.0",
    "@react-google-maps/api": "^2.20.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/cors": "^2.8.19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "chromadb": "^3.4.3",
    "concurrently": "^9.2.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.5.11",
    "file-type": "^22.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jimp": "^1.6.1",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "memoizee": "^0.4.17",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.32.0",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "qrcode-reader": "^1.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "wouter": "^3.9.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.1"
  }
}