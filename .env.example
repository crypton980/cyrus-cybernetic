# ============================================================
# CYRUS v3.0 - Local Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED ----

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyrus

# Session secret (required in production - use a long random string)
SESSION_SECRET=replace-with-long-random-secret

# ---- AI / LLM ----

# OpenAI API key (required for GPT-4o features, optional if using local LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Alternative AI integrations endpoint (Azure OpenAI or compatible)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_MODEL=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Set to true to use open-source local models instead of OpenAI
USE_LOCAL_LLM=true
USE_LOCAL_VISION=true
USE_LOCAL_IMAGE_GEN=true

# ---- OPTIONAL SERVICES ----

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=

# Google Maps / Geocoding / Geolocation
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# Azure Document Intelligence (form recognition / OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Alpaca Markets (trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_ENVIRONMENT=paper

# Allow live trading (set to true only when ready)
ALLOW_LIVE_TRADING=false

# OpenID Connect (Replit Auth or other OIDC provider)
ISSUER_URL=

# Data encryption
ENCRYPTION_SECRET=
ENCRYPTION_SALT=

# ---- DEVICE CONTROL ----

DEVICE_CONTROL_ENABLED=false
DEVICE_ALLOWLIST_APPS=
DEVICE_DEFAULT_APP=
DEVICE_CONFIRM_TOKEN=
DEVICE_DRY_RUN_DEFAULT=true

# ---- SERVER ----

PORT=3105
NODE_ENV=development

# Optional: enable only if your platform supports socket port reuse
ENABLE_REUSE_PORT=false

# Auth access codes (REQUIRED in production — set strong values)
# In development, fallback codes 71580019 / 170392 are used automatically
ADMIN_ACCESS_CODE=
USER_ACCESS_CODE=
ADMIN_USERNAME=DELTA UNIFORM 00

# ── CYRUS AI Microservice ──────────────────────────────────────────────────────
# URL for the Python FastAPI intelligence service (memory, brain, learning)
# In Docker: http://localhost:8001 (both services share the network namespace)
# Override when deploying AI service separately
CYRUS_AI_URL=http://localhost:8001
CYRUS_AI_TIMEOUT_MS=8000

# Directory for ChromaDB persistent vector storage (used by cyrus-ai/api.py)
CHROMA_PERSIST_DIR=./chroma_data

# Comma-separated allowed origins for the Python AI service CORS policy
# Must include the URL the Node.js backend is accessed from
AI_ALLOWED_ORIGINS=http://localhost:3105

# ── Session Memory (Redis) ─────────────────────────────────────────────────────
# Redis connection URL for short-term session memory (last 10 interactions)
# Leave empty or omit to disable Redis — session memory will be a no-op
REDIS_URL=redis://127.0.0.1:6379
CYRUS_SESSION_TTL=3600
CYRUS_SESSION_DEPTH=10

# ── Autonomy Loop ──────────────────────────────────────────────────────────────
# Interval (seconds) between autonomy heartbeat cycles
CYRUS_AUTONOMY_INTERVAL_SEC=30
# Alert threshold for vector memory collection size
CYRUS_MAX_MEMORY_ENTRIES=100000

# ── Distributed Intelligence Network ──────────────────────────────────────────
# Unique identity for this CYRUS node (used in distributed events and cluster registry)
CYRUS_NODE_ID=node-primary
# Comma-separated list of peer node IDs for static cluster configuration
# (used by task router when Redis node registry is unavailable)
CYRUS_CLUSTER_NODES=node-primary
# Redis pub/sub channel for inter-node events
CYRUS_EVENT_CHANNEL=cyrus_events
# Task routing strategy: "random" (default) or "local"
CYRUS_TASK_ROUTE_STRATEGY=random

# ── Self-Improving Intelligence Platform ──────────────────────────────────────
# Reasoning mode: "openai" (default) | "local" | "hybrid"
# "hybrid" tries local model first, falls back to OpenAI
CYRUS_MODEL_MODE=openai
# HuggingFace model ID or local path for the local inference engine
# Recommended small model for CPU: "microsoft/phi-2"
# Recommended for GPU: "mistralai/Mistral-7B-Instruct-v0.2"
CYRUS_LOCAL_MODEL=microsoft/phi-2
# Path to a fine-tuned checkpoint directory (overrides CYRUS_LOCAL_MODEL when set)
CYRUS_LOCAL_MODEL_DIR=
# Maximum new tokens to generate per local inference call
CYRUS_LOCAL_MAX_TOKENS=256
# Device for local model: "auto" | "cpu" | "cuda" | "mps"
CYRUS_LOCAL_DEVICE=auto
# Root output directory for fine-tuned checkpoints
CYRUS_MODEL_OUTPUT_DIR=./model_output
# JSONL file path for the interaction training dataset
CYRUS_TRAINING_DATASET=./training_data.jsonl
# Minimum evaluation score for an example to be logged (0.0–1.0)
CYRUS_MIN_QUALITY_SCORE=0.5
# Minimum training examples required before a fine-tuning run can start
CYRUS_MIN_TRAIN_EXAMPLES=50
# Enable autonomous fine-tuning when metrics indicate learning is needed
# Set to "true" only when GPU / sufficient RAM is available
CYRUS_AUTO_TRAIN=false
# Minimum seconds between autonomous training runs (prevents thrashing)
CYRUS_TRAIN_COOLDOWN_SEC=3600
# Number of epochs per fine-tuning run
CYRUS_TRAIN_EPOCHS=1
# Per-device training batch size
CYRUS_TRAIN_BATCH_SIZE=2


# ── Safety Control System (v8) ─────────────────────────────────────────────────
# Comma-separated action types that require human approval before execution
# Default: webhook. Set to empty string to disable approval gate.
CYRUS_REQUIRE_APPROVAL=webhook
# Seconds before a pending approval request auto-expires
CYRUS_APPROVAL_TTL_SEC=3600
# Audit log JSONL file path (immutable, append-only)
CYRUS_AUDIT_FILE=./audit_log.jsonl
# Emit a WARNING when the audit log exceeds this many entries
CYRUS_AUDIT_MAX_LINES=500000
# Optional file path: if this file exists at startup, system starts in lockdown
CYRUS_LOCKDOWN_FILE=
# Maximum missions retained in the in-process mission store
CYRUS_MAX_MISSIONS=1000


# ── Production Infrastructure (v9) ────────────────────────────────────────────

# ─ Logging ────────────────────────────────────────────────────────────────────
# Log level for both Node.js and Python services (debug|info|warning|error)
CYRUS_LOG_LEVEL=info
# Log format: "pretty" (colourised, human-readable) | "json" (structured JSON lines)
CYRUS_LOG_FORMAT=pretty
# Optional: write Python logs to this file (leave blank to disable)
CYRUS_LOG_FILE=
# Python log file rotation size in bytes (default: 10 MB)
CYRUS_LOG_MAX_BYTES=10485760
# Number of rotated Python log files to retain
CYRUS_LOG_KEEP=7
# Node.js log format override (json|pretty)
LOG_FORMAT=pretty
# Node.js log level override
LOG_LEVEL=info

# ─ Distributed Tracing (OpenTelemetry) ────────────────────────────────────────
# Set to "false" to disable all tracing
CYRUS_TRACING_ENABLED=true
# Service name reported in traces
OTEL_SERVICE_NAME=cyrus-ai
# OTLP gRPC endpoint for Jaeger / Grafana Tempo (leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
# Print spans to stdout for local debugging
CYRUS_TRACING_CONSOLE=false

# ─ Alerting ───────────────────────────────────────────────────────────────────
# Webhook URL for alert delivery (Slack, PagerDuty, etc.)
CYRUS_ALERT_WEBHOOK_URL=
# Error rate fraction that triggers a HIGH_ERROR_RATE alert (0.0-1.0)
CYRUS_ALERT_ERROR_RATE_THRESHOLD=0.3
# Seconds before the same alert message can be re-fired
CYRUS_ALERT_COOLDOWN_SEC=300
# Maximum alerts to keep in the in-process history ring buffer
CYRUS_ALERT_HISTORY_SIZE=500

# ─ Backup & Recovery ──────────────────────────────────────────────────────────
# Directory to store backup archives
CYRUS_BACKUP_DIR=./backups
# Number of days to retain backup archives
CYRUS_BACKUP_KEEP=7
# Colon-separated additional paths to include in backups
CYRUS_BACKUP_PATHS=

# ─ Config Hardening ───────────────────────────────────────────────────────────
# Comma-separated env var names that MUST be set in production
# (service will refuse to start if any are missing when NODE_ENV=production)
CYRUS_REQUIRED_ENV=CYRUS_NODE_ID

# ─ Embodied Intelligence ──────────────────────────────────────────────────────
# Drone (MAVLink / PX4)
# CYRUS_DRONE_CONNECTION=udp:127.0.0.1:14550   # MAVLink connection string
# CYRUS_DRONE_TIMEOUT_SEC=10                    # heartbeat wait timeout
# CYRUS_DRONE_SIMULATED=true                    # force simulated mode (no hardware)
CYRUS_DRONE_SIMULATED=true

# Vision system (YOLO)
# CYRUS_VISION_MODEL=yolov5s                    # YOLO model id (yolov5s/yolov8n/…)
# CYRUS_VISION_CONF=0.45                        # detection confidence threshold
# CYRUS_VISION_CAMERA=0                         # camera index or RTSP URL
# CYRUS_VISION_SIMULATED=true                   # force simulated mode (no camera)
CYRUS_VISION_SIMULATED=true

# Mission engine
# CYRUS_MISSION_STEP_PAUSE_SEC=2                # pause between mission steps (sec)
# CYRUS_MISSION_MAX_ALT_M=120                   # hard altitude ceiling (metres)

# Core loop
# CYRUS_EMBODIMENT_TICK_SEC=1.0                 # loop tick interval (seconds)
# CYRUS_EMBODIMENT_AUTO_MISSION=true            # auto-dispatch missions from brain

# Human interaction
# CYRUS_INTERACTION_MAX_HISTORY=20              # max messages per user
# CYRUS_INTERACTION_ADAPTIVE_AFTER=5            # turns before adaptive mode

# ─ CYRUS AI Microservice startup ──────────────────────────────────────────────
# Port the FastAPI service listens on (default: 8001)
CYRUS_AI_PORT=8001
# Number of uvicorn workers (default: 1 — set higher for production load)
CYRUS_AI_WORKERS=1
