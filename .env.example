# ============================================================
# CYRUS v3.0 - Local Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED ----

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyrus

# Session secret (required in production - use a long random string)
SESSION_SECRET=replace-with-long-random-secret

# ---- AI / LLM ----

# OpenAI API key (required for GPT-4o features, optional if using local LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Alternative AI integrations endpoint (Azure OpenAI or compatible)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_MODEL=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Set to true to use open-source local models instead of OpenAI
USE_LOCAL_LLM=true
USE_LOCAL_VISION=true
USE_LOCAL_IMAGE_GEN=true

# ---- OPTIONAL SERVICES ----

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=

# Google Maps / Geocoding / Geolocation
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# Azure Document Intelligence (form recognition / OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Alpaca Markets (trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_ENVIRONMENT=paper

# Allow live trading (set to true only when ready)
ALLOW_LIVE_TRADING=false

# OpenID Connect (Replit Auth or other OIDC provider)
ISSUER_URL=

# Data encryption
ENCRYPTION_SECRET=
ENCRYPTION_SALT=

# ---- DEVICE CONTROL ----

DEVICE_CONTROL_ENABLED=false
DEVICE_ALLOWLIST_APPS=
DEVICE_DEFAULT_APP=
DEVICE_CONFIRM_TOKEN=
DEVICE_DRY_RUN_DEFAULT=true

# ---- SERVER ----

PORT=3105
NODE_ENV=development

# Optional: enable only if your platform supports socket port reuse
ENABLE_REUSE_PORT=false

# Auth access codes (REQUIRED in production — set strong values)
# In development, fallback codes 71580019 / 170392 are used automatically
ADMIN_ACCESS_CODE=
USER_ACCESS_CODE=
ADMIN_USERNAME=DELTA UNIFORM 00

# ---- PRODUCTION / PUBLIC ACCESS ----

# Public base URL for the application (used when server is exposed via a domain)
# Example: https://cyrus.example.com
# Leave empty for relative-URL mode (recommended when frontend is served by this server)
BASE_URL=

# CORS: allowed origins for cross-origin API requests
# Comma-separated list of allowed origins. Leave empty to allow all origins (open API mode).
# Example: https://cyrus.example.com,https://www.cyrus.example.com
CORS_ALLOWED_ORIGINS=

# Redis URL (optional — gracefully degraded when absent)
REDIS_URL=redis://localhost:6379

# Internal service URLs — override when services run on separate hosts/containers
QUANTUM_BRIDGE_URL=http://127.0.0.1:5001
ML_SERVICE_URL=http://127.0.0.1:5002

# Python service bind hosts (0.0.0.0 to accept external connections; 127.0.0.1 for loopback-only)
QUANTUM_BRIDGE_HOST=0.0.0.0
ML_SERVICE_HOST=0.0.0.0

