# ============================================================
# CYRUS v3.0 - Local Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED ----

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyrus_ai

# AI Configuration - CYRUS now supports both OpenAI and Local AI
# Set USE_LOCAL_LLM=true to use open-source models (recommended for independence)
USE_LOCAL_LLM=true
USE_LOCAL_VISION=true
USE_LOCAL_IMAGE_GEN=true

# OpenAI API (optional - system works with local alternatives)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# AI_INTEGRATIONS_OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# AI_INTEGRATIONS_OPENAI_MODEL=

# Session secret (required in production)
SESSION_SECRET=replace-with-long-random-secret

# ---- OPTIONAL SERVICES ----

ELEVENLABS_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=
NEWS_API_KEY=

# ---- SERVER ----

PORT=3200
SERVER_HOST=0.0.0.0
PUBLIC_PROTOCOL=http
PUBLIC_DOMAIN=cyrus.local
BASE_URL=http://cyrus.local:3200

# Optional: enable only if your platform supports socket port reuse
ENABLE_REUSE_PORT=false
