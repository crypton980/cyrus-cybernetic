# ============================================================
# CYRUS v3.0 - Local Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- REQUIRED ----

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cyrus

# OpenAI API key used across CYRUS AI modules
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional alias used by parts of the codebase
AI_INTEGRATIONS_OPENAI_API_KEY=

# Optional model override used by inference/refinement fallback chain
OPENAI_MODEL=gpt-4o
AI_INTEGRATIONS_OPENAI_MODEL=

# Session secret (required in production)
SESSION_SECRET=replace-with-long-random-secret

# ---- OPTIONAL SERVICES ----

ELEVENLABS_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_GEOLOCATION_API_KEY=
NEWS_API_KEY=

# ---- SERVER ----

PORT=5000

# Optional: enable only if your platform supports socket port reuse
ENABLE_REUSE_PORT=false
