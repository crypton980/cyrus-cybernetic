{
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.hotExit": "onExitAndWindowClose",
    "workbench.localHistory.enabled": true,
    "workbench.localHistory.maxFileEntries": 100,
    "workbench.localHistory.maxFileSize": 512,
    "workbench.localHistory.mergeWindow": 10,
    "workbench.localHistory.exclude": {
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/dist/**": true,
        "**/__pycache__/**": true,
        "**/*.tar.gz": true
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/server",
        "${workspaceFolder}/server/quantum_ai",
        "${workspaceFolder}/server/quantum_ai/core_algorithms",
        "${workspaceFolder}/shared"
    ],
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.includeFileSpecs": [
        "**/*.py"
    ],
    "python.analysis.exclude": [
        "**/__pycache__",
        "**/.venv",
        "**/node_modules",
        "**/dist",
        "**/*.tar.gz",
        "quantum_nexus_part_*",
        "quantum_nexus_smaller_*"
    ],
    "python.languageServer": "Pylance",
    "python.analysis.indexing": true,
    "python.analysis.packageIndexDepths": [
        {
            "name": "pyserial",
            "depth": 2
        },
        {
            "name": "pyusb",
            "depth": 2
        },
        {
            "name": "paho-mqtt",
            "depth": 2
        },
        {
            "name": "pymodbus",
            "depth": 2
        }
    ],
    "python.analysis.diagnosticSeverityOverrides": {
        "reportUnknownMemberType": "none",
        "reportUnknownVariableType": "none",
        "reportUnknownArgumentType": "none",
        "reportUnknownLambdaType": "none",
        "reportMissingTypeStubs": "none"
    },
    "python-envs.defaultEnvManager": "ms-python.python:local",
    "typescript.tsdk": "${workspaceFolder}/node_modules/typescript/lib",
    "typescript.preferences.importModuleSpecifier": "relative",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "quantum_nexus_part_*": true,
        "quantum_nexus_smaller_*": true,
        "**/*.tar.gz": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.venv": true,
        "**/dist": true,
        "quantum_nexus_part_*": true,
        "quantum_nexus_smaller_*": true,
        "**/*.tar.gz": true,
        "uv.lock": true,
        "package-lock.json": true
    }
}